# .gitattributes

# По умолчанию все текстовые файлы- LF
* text=auto eol=lf

# Эти файлы ДОЛЖНЫ быть CRLF (для Windows)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Бинарные файлы не трогаем (важно!)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary