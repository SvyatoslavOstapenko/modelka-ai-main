{
  "name": "modelka-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:db": "docker compose --env-file .env -f docker-compose.dev.yml up -d",
    "dev:db:stop": "docker compose --env-file .env -f docker-compose.dev.yml down",
    "dev:db:wait": "docker compose --env-file .env -f docker-compose.dev.yml exec db-dev sh -c \"pg_isready -h 127.0.0.1 -U ${POSTGRES_USER:-postgres} -d ${POSTGRES_DB:-postgres}\" || timeout /t 5 && docker compose --env-file .env -f docker-compose.dev.yml exec db-dev sh -c \"pg_isready -h 127.0.0.1 -U ${POSTGRES_USER:-postgres} -d ${POSTGRES_DB:-postgres}\"",
    "dev:start": "npm run dev:db && npm run dev:db:wait && npm run db:push && npm run dev",
    "build": "next build",
    "verify:build": "docker compose -f docker-compose.verify.yml build --no-cache",
    "verify:up": "docker compose -f docker-compose.verify.yml up -d --build",
    "verify:logs": "docker logs verify_app -f",
    "verify:down": "docker compose -f docker-compose.verify.yml down -v",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "hooks:install": "bash scripts/install-git-hooks.sh || scripts/install-git-hooks.bat",
    "start": "next start",
    "lint": "eslint",
    "db:push": "drizzle-kit push",
    "db:migrate": "npx tsx --env-file .env src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:check": "bash scripts/check-db-schema.sh local || scripts/check-db-schema.bat local",
    "db:check:prod": "bash scripts/check-db-schema.sh prod || scripts/check-db-schema.bat prod"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@aws-sdk/client-s3": "^3.946.0",
    "@aws-sdk/lib-storage": "^3.948.0",
    "@aws-sdk/s3-request-presigner": "^3.946.0",
    "@fal-ai/client": "^1.7.2",
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.3.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/uuid": "^10.0.0",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.35.7",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.26",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.555.0",
    "next": "16.0.7",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.68.0",
    "resend": "^6.5.2",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "overrides": {
    "@auth/core": "0.41.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.0.15",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "ngrok": "^5.0.0-beta.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.15"
  }
}
